# Port for Express API
PORT=5000

# Google AI Keys
GEMINI_API_KEY=your_gemini_api_key_here
GOOGLE_CLOUD_VISION_KEY=your_google_cloud_vision_key_here

# Google Maps API Key (Client)
REACT_APP_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Firebase Web Client Configuration (Client - JSON string or separate keys)
# E.g. {"apiKey":"...","authDomain":"...","projectId":"...","storageBucket":"...","messagingSenderId":"...","appId":"..."}
REACT_APP_FIREBASE_CONFIG={"apiKey":"your_api_key","authDomain":"your_project.firebaseapp.com","projectId":"your_project_id","storageBucket":"your_project.appspot.com","messagingSenderId":"your_sender_id","appId":"your_app_id"}

# Firebase Admin SDK Configuration (Server - JSON string format)
# E.g. {"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}
FIREBASE_ADMIN_SDK=your_firebase_admin_sdk_json_here
